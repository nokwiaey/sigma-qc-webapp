function SetUser(){
    var labindex = $("#Labindex").val();
    var danwei = $("#Danwei").val();
    var keshi = $("#Keshi").val();
    var contact = $("#Contact").val();
    var phone = $("#Phone").val();
    var email = $("#Email").val();
    var mobile = $("#Mobile").val();

    if (labindex == "") {
        alert("实验室编码不能为空(如果没有实验室编码，请填写您的用户名)");
        return;
    }

    if (danwei == "") {
        alert("实验室名称不能为空");
        return;
    }

    if (keshi == "") {
        alert("科室不能为空");
        return;
    }

    if (contact == "") {
        alert("联系人不能为空");
        return;
    }

    if (phone == "") {
        alert("电话不能为空");
        return;
    }

    if (email == "") {
        alert("Email不能为空");
        return;
    }

    if (mobile == "") {
        alert("手机不能为空");
        return;
    }

    Set(labindex, danwei, keshi, contact, phone, email, mobile);
}

function Set(labindex, danwei, keshi, contact, phone, email, mobile) {
    $.ajax({ "url": "AjaxServiceUser.ashx", "type": "POST", "cache": false, "data": { "type": "set", "labindex": labindex, "danwei": danwei, "keshi": keshi, "contact": contact, "phone": phone, "email": email, "mobile": mobile }, "success": SetSuccess, "error": SetError });
}

function SetSuccess(str) {
    if (str != "error") {

        var json = eval("(" + str + ")");

        $("#Labindex").val(json["labindex"]);
        $("#Danwei").val(json["danwei"]);
        $("#Keshi").val(json["keshi"]);

        $("#Contact").val(json["contact"]);
        $("#Phone").val(json["phone"]);
        $("#Email").val(json["email"]);
        $("#Mobile").val(json["mobile"]);

        CheckUserInfo();
        alert("保存成功");

    } else {
        alert("操作失败");   
    }
}

function SetError(str) {
    alert("操作失败");
}


function CheckUserInfo() {
    var labindex = $("#Labindex").val();
    var danwei = $("#Danwei").val();
    var keshi = $("#Keshi").val();
    var contact = $("#Contact").val();
    var phone = $("#Phone").val();
    var email = $("#Email").val();
    var mobile = $("#Mobile").val();

    if (labindex != "" && danwei != "" && keshi != "" && contact != "" && phone != "" && email != "" && mobile != "") {
        $("#btnAdd,#btnPrint").prop("disabled", false);
    } else {
        $("#btnAdd,#btnPrint").prop("disabled", true);
    }
}