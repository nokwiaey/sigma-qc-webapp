//生成固定的
function GetLineData(SeriesCount)
{
	var str="";
	var colors=["#FF8080","#FFFF00","#00FF40","#4032EB","#969EED"]
	var s = '{type:"line",color:"{$color}","zIndex":900,"data":[{"x":{$x0},"y":{$y0}},{"x":{$x1},"y":{$y1}}]}';
	
	for(var i=0;i<SeriesCount;i++)
	{
		var sigma=i+2;
		var x=0;
		var y=1-sigma * x;
		var s0=s.replace("{$color}",colors[i]);
		s0=s0.replace("{$x0}",x*100);
		s0=s0.replace("{$y0}",y*100);
		
		y=0;
		x=(1-y)/sigma;
		s0=s0.replace("{$x1}",x*100);
		s0=s0.replace("{$y1}",y*100);
		
		if(i==0)
		{
		  str=str + s0;
		}else
		{
		  str=str +","+ s0;	
		}
		
		
	}
	return str;
}

function GetScatterData()
{
	var str="";
	var s = '{"type":"scatter","name":"{$name}","zIndex":1000,"color":"{$color}","marker":{"symbol":"{$symbol}"},"data":[{"x":{$x},"y":{$y},"xo":{$xo},"yo":{$yo},"xgm":{$xgm},"per":"{$per}"}]}';
	var i=0;
	//alert($("#table0 tr:gt(0)").size());
	$("#table0 tr:gt(0)").each(function (index, element) {
	    var me = $(element);
	    var name = me.find("td:eq(0)").html();
	    var tea = parseFloat(me.find("td:eq(1)").html());
	    var cv = parseFloat(me.find("td:eq(2)").html());
	    var bias = Math.abs(parseFloat(me.find("td:eq(3)").html()));
	    var sigma = parseFloat(me.find("td:eq(4)").html());
	    var per = me.find("td:eq(5)").html();
	    var x = cv / tea;
	    var y = bias / tea;
	    var xo = x;
	    var yo = y;

	    var s0 = s.replace("{$color}", GetScatterColor(per));

	    if (x > 0.5 || y > 1) {
	        s0 = s0.replace("{$symbol}", "url(images/c.png)");
	    } else {
	        s0 = s0.replace("{$symbol}", "circle");
	    }

	    if (x > 0.5) {
	        x = 0.5;
	    }
	    if (y > 1) {
	        y = 1;
	    }




	    s0 = s0.replace("{$name}", name);
	    s0 = s0.replace("{$x}", x * 100);
	    s0 = s0.replace("{$y}", y * 100);
	    s0 = s0.replace("{$xo}", xo * 100);
	    s0 = s0.replace("{$yo}", yo * 100);
	    s0 = s0.replace("{$xgm}", sigma);
	    s0 = s0.replace("{$per}", per);

	    if (i == 0) {
	        str = str + s0;
	    } else {
	        str = str + "," + s0;
	    }
	    i++;
	});
	return str;
}

function GetScatterColor(per)
{
    if(per=="世界一流")	
	{
		return "#00ff00";
	}
	else if(per=="优秀")
	{
		return "#008080";
	}
	else if(per=="良好")
	{
		return "#87CEEB";
	}
	else if(per=="临界")
	{
		return "#800080";
	}
	else if(per=="欠佳")
	{
		return "#800000";
	}
	else if(per=="不可接受")
	{
		return "#FF0000";
	}
	else
	{
	    return "#000000";	
	}

}

function GetGuize(per) {
    if (per == "世界一流") {
        return "1<sub>3s</sub>(N=2,R=1)";
    }
    else if (per == "优秀") {
        return "1<sub>3s</sub>2<sub>2s</sub>R<sub>4s</sub><br />(N=2,R=1)";
    }
    else if (per == "良好") {
        return "1<sub>3s</sub>2<sub>2s</sub>R<sub>4s</sub>4<sub>1s</sub><br />(N=4,R=1或N=2,R=2)";
    }
    else if (per == "临界") {
        return "1<sub>3s</sub>2<sub>2s</sub>R<sub>4s</sub>4<sub>1s</sub>8<sub style=\"\">x</sub><br />(N=4,R=2或N=2,R=4)";
    } else {
        return "";
    }
}

