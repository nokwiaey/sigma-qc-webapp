function MyAdd()
{
  var ItemName=$("#ItemName").val();
  var Tea=$("#Tea").val();
  var CV=$("#CV").val();
  var Bias=$("#Bias").val();
  
  var reg=/^[-\+]?\d+(\.\d+)?$/;
  
  
  if(ItemName=="")
  {
     alert("项目名称不能为空");
	 return;
  }
  if(reg.test(Tea)==false)
  {
     alert("允许总误差是必填项，且只能填写数字");
	 return;
  }
  if(reg.test(CV)==false)
  {
     alert("不精密度是必填项，且只能填写数字");
	 return;
  }
  if(reg.test(Bias)==false)
  {
     alert("偏倚是必填项，且只能填写数字");
	 return;
  }
  
  Tea=parseFloat(Tea);
  CV=parseFloat(CV);
  Bias=parseFloat(Bias);
  
  if(Tea<=0)
  {
     alert("允许总误差必须大于0");
	 return;
  }
  if(CV<=0)
  {
     alert("不精密度必须大于0");
	 return;
  }
  if(Bias<0)
  {
     alert("偏倚必须大于或等于0");
	 return;
  }
  
  Add(ItemName,Tea,CV,Bias);
}

function MyDel(obj)
{
