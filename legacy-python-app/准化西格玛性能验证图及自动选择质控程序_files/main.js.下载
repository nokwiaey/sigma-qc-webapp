function GetPrinterUrl(){
	return "http://srv.clinet.cn/printpdf/printpdffromwebpage.ashx";
}

function PrintPdf(labindex) {
	if ($("#table0 tr").size()>1) {
		var LocationUrl = location.href;
		var locationDir = LocationUrl.substring(0, LocationUrl.lastIndexOf("/") + 1);
        var AbsPath = locationDir + "pdf.aspx?labindex=" + labindex;
        if (v == "2") {
            AbsPath = AbsPath + "&v=2";
        }
		var PrinterUrl = GetPrinterUrl();
		var date=new Date();
		var p = date.getFullYear() % date.getDate();
		$("#download").html("&nbsp;正在打印...");
		$.ajax({ "url": PrinterUrl,
			 "dataType": "jsonp",
			 "jsonp": "callback",
			 "jsonpCallback":"CallbackFun",
			 "cache": false,
			 "data":{ "webpage": AbsPath,"delay":"2500","p":p+"","app":"xgmpv","u":labindex}
		  });
		
	} else {
	   alert("您没有添加任何数据，不能进行打印");
	}
}

